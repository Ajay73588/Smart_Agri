# TrustAgri — Environment Variable Template
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.

# OpenWeatherMap API key — https://openweathermap.org/api
# Used for: real-time temperature and humidity for a district
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Agmarknet / data.gov.in API key — https://data.gov.in/
# Used for: live crop modal prices by state and district
AGMARKNET_API_KEY=your_agmarknet_api_key_here
